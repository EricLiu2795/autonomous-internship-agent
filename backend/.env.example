# Anthropic API Key (OPTIONAL - only needed as Tier 2 fallback)
# Ara includes Claude access, so this is only for redundancy
# Get from https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_api_key_here

# Notion Integration (OPTIONAL - uses demo mode if not set)
# To enable real Notion API sync, set both:
# NOTION_API_KEY=secret_xxxxx
# NOTION_DATABASE_ID=xxxxx

# Server Configuration
PORT=3001
NODE_ENV=development
